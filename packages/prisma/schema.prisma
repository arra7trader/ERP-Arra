// =====================================================
// PICA ERP - Enterprise Resource Planning System
// Modern, Scalable, and Comprehensive Database Schema
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// CORE MODULE - Authentication & Authorization
// =====================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?
  
  roles         UserRole[]
  employee      Employee?
  sessions      Session[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([isActive])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)
  
  users       UserRole[]
  permissions RolePermission[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  module      String
  action      String
  description String?
  
  roles       RolePermission[]
  
  createdAt   DateTime         @default(now())

  @@index([module])
  @@index([name])
}

model RolePermission {
  roleId       String
  permissionId String
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@id([roleId, permissionId])
}

model UserRole {
  userId    String
  roleId    String
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  assignedAt DateTime @default(now())
  
  @@id([userId, roleId])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

// =====================================================
// HRM MODULE - Human Resource Management
// =====================================================

model Department {
  id          String     @id @default(uuid())
  name        String
  code        String     @unique
  description String?
  parentId    String?
  managerId   String?
  
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]
  positions   Position[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([code])
}

model Position {
  id           String     @id @default(uuid())
  title        String
  code         String     @unique
  departmentId String
  level        Int        @default(1)
  minSalary    Decimal?   @db.Decimal(15, 2)
  maxSalary    Decimal?   @db.Decimal(15, 2)
  description  String?
  
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

model Employee {
  id              String    @id @default(uuid())
  employeeCode    String    @unique
  userId          String?   @unique
  departmentId    String?
  positionId      String?
  managerId       String?
  
  firstName       String
  lastName        String
  email           String    @unique
  phone           String?
  dateOfBirth     DateTime?
  gender          String?
  maritalStatus   String?
  nationality     String?
  idNumber        String?
  
  // Address
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  
  // Employment Details
  employmentType  String    @default("full-time") // full-time, part-time, contract, intern
  employmentStatus String   @default("active") // active, inactive, terminated, resigned
  hireDate        DateTime
  terminationDate DateTime?
  probationEndDate DateTime?
  
  // Salary & Bank
  baseSalary      Decimal?  @db.Decimal(15, 2)
  bankName        String?
  bankAccount     String?
  taxId           String?
  
  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  
  user            User?      @relation(fields: [userId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
  position        Position?  @relation(fields: [positionId], references: [id])
  manager         Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates    Employee[] @relation("EmployeeManager")
  
  attendances     Attendance[]
  leaves          Leave[]
  payrolls        Payroll[]
  documents       EmployeeDocument[]
  performanceReviews PerformanceReview[]
  trainings       EmployeeTraining[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([employeeCode])
  @@index([departmentId])
  @@index([positionId])
  @@index([employmentStatus])
}

model EmployeeDocument {
  id          String   @id @default(uuid())
  employeeId  String
  name        String
  type        String
  fileUrl     String
  expiryDate  DateTime?
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  date        DateTime  @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      String    @default("present") // present, absent, late, half-day, leave
  workHours   Decimal?  @db.Decimal(4, 2)
  overtimeHours Decimal? @db.Decimal(4, 2)
  notes       String?
  location    String?
  
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model LeaveType {
  id              String   @id @default(uuid())
  name            String   @unique
  code            String   @unique
  description     String?
  defaultDays     Int      @default(0)
  isPaid          Boolean  @default(true)
  requiresApproval Boolean @default(true)
  color           String?
  
  leaves          Leave[]
  leaveBalances   LeaveBalance[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LeaveBalance {
  id           String    @id @default(uuid())
  employeeId   String
  leaveTypeId  String
  year         Int
  totalDays    Decimal   @db.Decimal(5, 2)
  usedDays     Decimal   @default(0) @db.Decimal(5, 2)
  
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model Leave {
  id            String    @id @default(uuid())
  employeeId    String
  leaveTypeId   String
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  totalDays     Decimal   @db.Decimal(5, 2)
  reason        String?
  status        String    @default("pending") // pending, approved, rejected, cancelled
  approvedById  String?
  approvedAt    DateTime?
  rejectionReason String?
  
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
}

model PayrollPeriod {
  id          String    @id @default(uuid())
  name        String
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  payDate     DateTime  @db.Date
  status      String    @default("draft") // draft, processing, completed, paid
  
  payrolls    Payroll[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Payroll {
  id              String        @id @default(uuid())
  employeeId      String
  periodId        String
  
  baseSalary      Decimal       @db.Decimal(15, 2)
  allowances      Decimal       @default(0) @db.Decimal(15, 2)
  overtime        Decimal       @default(0) @db.Decimal(15, 2)
  deductions      Decimal       @default(0) @db.Decimal(15, 2)
  tax             Decimal       @default(0) @db.Decimal(15, 2)
  netSalary       Decimal       @db.Decimal(15, 2)
  
  status          String        @default("draft") // draft, approved, paid
  paidAt          DateTime?
  paymentMethod   String?
  paymentRef      String?
  notes           String?
  
  employee        Employee      @relation(fields: [employeeId], references: [id])
  period          PayrollPeriod @relation(fields: [periodId], references: [id])
  items           PayrollItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([employeeId, periodId])
  @@index([periodId])
  @@index([status])
}

model PayrollItem {
  id          String   @id @default(uuid())
  payrollId   String
  type        String   // earning, deduction, tax
  name        String
  amount      Decimal  @db.Decimal(15, 2)
  
  payroll     Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([payrollId])
}

model PerformanceReview {
  id           String   @id @default(uuid())
  employeeId   String
  reviewerId   String
  period       String
  rating       Decimal  @db.Decimal(3, 2)
  strengths    String?
  improvements String?
  goals        String?
  comments     String?
  status       String   @default("draft") // draft, submitted, acknowledged
  
  employee     Employee @relation(fields: [employeeId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
}

model Training {
  id          String   @id @default(uuid())
  title       String
  description String?
  trainer     String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  cost        Decimal? @db.Decimal(15, 2)
  maxParticipants Int?
  status      String   @default("scheduled") // scheduled, ongoing, completed, cancelled
  
  participants EmployeeTraining[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmployeeTraining {
  id          String   @id @default(uuid())
  employeeId  String
  trainingId  String
  status      String   @default("enrolled") // enrolled, completed, cancelled
  completedAt DateTime?
  score       Decimal? @db.Decimal(5, 2)
  certificate String?
  
  training    Training @relation(fields: [trainingId], references: [id])
  
  createdAt   DateTime @default(now())

  @@unique([employeeId, trainingId])
}

model Recruitment {
  id           String   @id @default(uuid())
  title        String
  departmentId String?
  positionId   String?
  description  String?
  requirements String?
  salaryRange  String?
  location     String?
  employmentType String @default("full-time")
  openings     Int      @default(1)
  status       String   @default("open") // open, closed, on-hold
  postedAt     DateTime @default(now())
  closingDate  DateTime?
  
  applicants   Applicant[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model Applicant {
  id            String     @id @default(uuid())
  recruitmentId String
  name          String
  email         String
  phone         String?
  resumeUrl     String?
  coverLetter   String?
  status        String     @default("new") // new, screening, interview, offer, hired, rejected
  rating        Int?
  notes         String?
  
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id])
  interviews    Interview[]
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([recruitmentId])
  @@index([status])
}

model Interview {
  id          String    @id @default(uuid())
  applicantId String
  scheduledAt DateTime
  interviewers String[]
  type        String    @default("onsite") // onsite, phone, video
  status      String    @default("scheduled") // scheduled, completed, cancelled
  feedback    String?
  rating      Int?
  
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([applicantId])
}

// =====================================================
// INVENTORY MODULE - Warehouse & Stock Management
// =====================================================

model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?
  image       String?
  
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
}

model ProductBrand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  logo        String?
  description String?
  website     String?
  
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UnitOfMeasure {
  id           String    @id @default(uuid())
  name         String    @unique
  symbol       String    @unique
  baseUnit     String?
  conversionRate Decimal? @db.Decimal(15, 6)
  
  products     Product[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id              String    @id @default(uuid())
  sku             String    @unique
  barcode         String?   @unique
  name            String
  description     String?
  categoryId      String?
  brandId         String?
  unitId          String?
  
  type            String    @default("goods") // goods, service, digital
  costPrice       Decimal   @default(0) @db.Decimal(15, 2)
  sellingPrice    Decimal   @default(0) @db.Decimal(15, 2)
  minStockLevel   Int       @default(0)
  maxStockLevel   Int?
  reorderPoint    Int       @default(0)
  reorderQuantity Int       @default(1)
  
  weight          Decimal?  @db.Decimal(10, 3)
  dimensions      String?
  
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  trackInventory  Boolean   @default(true)
  allowBackorder  Boolean   @default(false)
  
  images          String[]
  tags            String[]
  attributes      Json?
  
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  brand           ProductBrand?    @relation(fields: [brandId], references: [id])
  unit            UnitOfMeasure?   @relation(fields: [unitId], references: [id])
  
  inventories     InventoryStock[]
  movements       InventoryMovement[]
  purchaseItems   PurchaseOrderItem[]
  salesItems      SalesOrderItem[]
  quotationItems  QuotationItem[]
  priceListItems  PriceListItem[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([isActive])
}

model Warehouse {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?
  phone       String?
  email       String?
  managerId   String?
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  
  locations   WarehouseLocation[]
  inventories InventoryStock[]
  movementsFrom InventoryMovement[] @relation("MovementFrom")
  movementsTo   InventoryMovement[] @relation("MovementTo")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model WarehouseLocation {
  id          String    @id @default(uuid())
  warehouseId String
  code        String
  name        String
  zone        String?
  aisle       String?
  rack        String?
  shelf       String?
  bin         String?
  
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventories InventoryStock[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model InventoryStock {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  locationId  String?
  
  quantity    Decimal   @default(0) @db.Decimal(15, 3)
  reserved    Decimal   @default(0) @db.Decimal(15, 3)
  available   Decimal   @default(0) @db.Decimal(15, 3)
  
  batchNumber String?
  expiryDate  DateTime?
  costPrice   Decimal?  @db.Decimal(15, 2)
  
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  location    WarehouseLocation? @relation(fields: [locationId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId, locationId, batchNumber])
  @@index([productId])
  @@index([warehouseId])
}

model InventoryMovement {
  id              String    @id @default(uuid())
  productId       String
  fromWarehouseId String?
  toWarehouseId   String?
  
  type            String    // in, out, transfer, adjustment
  reason          String?
  quantity        Decimal   @db.Decimal(15, 3)
  reference       String?
  referenceType   String?   // purchase_order, sales_order, adjustment, transfer
  referenceId     String?
  notes           String?
  
  product         Product   @relation(fields: [productId], references: [id])
  fromWarehouse   Warehouse? @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse? @relation("MovementTo", fields: [toWarehouseId], references: [id])
  
  createdAt       DateTime  @default(now())
  createdById     String?

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model StockAdjustment {
  id          String    @id @default(uuid())
  adjustmentNo String   @unique
  warehouseId String
  reason      String
  notes       String?
  status      String    @default("draft") // draft, approved, completed
  approvedById String?
  approvedAt  DateTime?
  
  items       StockAdjustmentItem[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?

  @@index([adjustmentNo])
  @@index([status])
}

model StockAdjustmentItem {
  id            String   @id @default(uuid())
  adjustmentId  String
  productId     String
  currentQty    Decimal  @db.Decimal(15, 3)
  adjustedQty   Decimal  @db.Decimal(15, 3)
  difference    Decimal  @db.Decimal(15, 3)
  reason        String?
  
  adjustment    StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([adjustmentId])
}

// =====================================================
// PROCUREMENT MODULE - Purchasing & Suppliers
// =====================================================

model Supplier {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  email         String?
  phone         String?
  website       String?
  
  // Address
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  
  // Contact Person
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  
  // Business Info
  taxId         String?
  paymentTerms  Int       @default(30)
  currency      String    @default("IDR")
  
  status        String    @default("active") // active, inactive, blacklisted
  rating        Int?
  notes         String?
  
  purchaseOrders PurchaseOrder[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([status])
}

model PurchaseOrder {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  supplierId    String
  warehouseId   String?
  
  orderDate     DateTime  @default(now())
  expectedDate  DateTime?
  
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  shippingCost  Decimal   @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(15, 2)
  
  status        String    @default("draft") // draft, sent, partial, received, cancelled
  paymentStatus String    @default("unpaid") // unpaid, partial, paid
  
  notes         String?
  terms         String?
  
  supplier      Supplier  @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]
  receipts      GoodsReceipt[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?

  @@index([orderNo])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id            String   @id @default(uuid())
  orderId       String
  productId     String
  
  quantity      Decimal  @db.Decimal(15, 3)
  receivedQty   Decimal  @default(0) @db.Decimal(15, 3)
  unitPrice     Decimal  @db.Decimal(15, 2)
  discount      Decimal  @default(0) @db.Decimal(15, 2)
  tax           Decimal  @default(0) @db.Decimal(15, 2)
  subtotal      Decimal  @db.Decimal(15, 2)
  
  order         PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())

  @@index([orderId])
}

model GoodsReceipt {
  id            String    @id @default(uuid())
  receiptNo     String    @unique
  purchaseOrderId String
  warehouseId   String
  
  receiptDate   DateTime  @default(now())
  status        String    @default("draft") // draft, completed
  notes         String?
  
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items         GoodsReceiptItem[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  receivedById  String?

  @@index([receiptNo])
  @@index([purchaseOrderId])
}

model GoodsReceiptItem {
  id            String   @id @default(uuid())
  receiptId     String
  productId     String
  quantity      Decimal  @db.Decimal(15, 3)
  batchNumber   String?
  expiryDate    DateTime?
  notes         String?
  
  receipt       GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([receiptId])
}

// =====================================================
// CRM & SALES MODULE - Customer Relationship Management
// =====================================================

model Customer {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  email         String?
  phone         String?
  
  // Address
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  
  // Business Info
  type          String    @default("individual") // individual, company
  companyName   String?
  taxId         String?
  
  // Credit
  creditLimit   Decimal   @default(0) @db.Decimal(15, 2)
  currentCredit Decimal   @default(0) @db.Decimal(15, 2)
  paymentTerms  Int       @default(30)
  
  // Contact Person
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  
  status        String    @default("active") // active, inactive
  source        String?   // website, referral, advertisement, etc.
  tags          String[]
  notes         String?
  
  leads         Lead[]
  contacts      Contact[]
  opportunities Opportunity[]
  quotations    Quotation[]
  salesOrders   SalesOrder[]
  invoices      Invoice[]
  payments      Payment[]
  activities    Activity[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([code])
  @@index([email])
  @@index([status])
}

model Contact {
  id          String    @id @default(uuid())
  customerId  String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  position    String?
  department  String?
  isPrimary   Boolean   @default(false)
  
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([customerId])
}

model Lead {
  id            String    @id @default(uuid())
  customerId    String?
  
  name          String
  email         String?
  phone         String?
  company       String?
  position      String?
  
  source        String?
  status        String    @default("new") // new, contacted, qualified, proposal, negotiation, won, lost
  priority      String    @default("medium") // low, medium, high
  
  estimatedValue Decimal? @db.Decimal(15, 2)
  expectedCloseDate DateTime?
  
  assignedToId  String?
  notes         String?
  tags          String[]
  
  customer      Customer? @relation(fields: [customerId], references: [id])
  activities    Activity[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([status])
  @@index([assignedToId])
}

model Opportunity {
  id            String    @id @default(uuid())
  customerId    String
  
  name          String
  stage         String    @default("prospecting") // prospecting, qualification, proposal, negotiation, closed_won, closed_lost
  probability   Int       @default(0)
  
  amount        Decimal   @default(0) @db.Decimal(15, 2)
  expectedCloseDate DateTime?
  actualCloseDate DateTime?
  
  source        String?
  competitor    String?
  assignedToId  String?
  notes         String?
  
  customer      Customer  @relation(fields: [customerId], references: [id])
  quotations    Quotation[]
  activities    Activity[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([customerId])
  @@index([stage])
  @@index([assignedToId])
}

model SalesPipeline {
  id          String    @id @default(uuid())
  name        String    @unique
  stages      Json      // Array of stage objects with name, probability, order
  isDefault   Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id            String    @id @default(uuid())
  type          String    // call, email, meeting, task, note
  subject       String
  description   String?
  
  customerId    String?
  leadId        String?
  opportunityId String?
  
  dueDate       DateTime?
  completedAt   DateTime?
  status        String    @default("pending") // pending, completed, cancelled
  priority      String    @default("medium")
  
  assignedToId  String?
  
  customer      Customer?    @relation(fields: [customerId], references: [id])
  lead          Lead?        @relation(fields: [leadId], references: [id])
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([customerId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([status])
  @@index([dueDate])
}

model Campaign {
  id            String    @id @default(uuid())
  name          String
  type          String    // email, sms, social, event
  status        String    @default("draft") // draft, scheduled, running, paused, completed
  
  startDate     DateTime?
  endDate       DateTime?
  budget        Decimal?  @db.Decimal(15, 2)
  actualCost    Decimal?  @db.Decimal(15, 2)
  
  targetAudience String?
  expectedRevenue Decimal? @db.Decimal(15, 2)
  actualRevenue Decimal?  @db.Decimal(15, 2)
  
  description   String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([status])
  @@index([type])
}

model PriceList {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  currency    String    @default("IDR")
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  
  items       PriceListItem[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model PriceListItem {
  id          String    @id @default(uuid())
  priceListId String
  productId   String
  
  price       Decimal   @db.Decimal(15, 2)
  minQuantity Decimal   @default(1) @db.Decimal(15, 3)
  discount    Decimal   @default(0) @db.Decimal(5, 2)
  
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([priceListId, productId, minQuantity])
  @@index([priceListId])
  @@index([productId])
}

model Quotation {
  id            String    @id @default(uuid())
  quotationNo   String    @unique
  customerId    String
  opportunityId String?
  
  quotationDate DateTime  @default(now())
  validUntil    DateTime
  
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(15, 2)
  
  status        String    @default("draft") // draft, sent, accepted, rejected, expired
  notes         String?
  terms         String?
  
  customer      Customer  @relation(fields: [customerId], references: [id])
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  items         QuotationItem[]
  salesOrders   SalesOrder[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([quotationNo])
  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  productId   String
  
  description String?
  quantity    Decimal   @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  discount    Decimal   @default(0) @db.Decimal(15, 2)
  tax         Decimal   @default(0) @db.Decimal(15, 2)
  subtotal    Decimal   @db.Decimal(15, 2)
  
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model SalesOrder {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  customerId    String
  quotationId   String?
  warehouseId   String?
  
  orderDate     DateTime  @default(now())
  deliveryDate  DateTime?
  
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  shippingCost  Decimal   @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(15, 2)
  
  status        String    @default("draft") // draft, confirmed, processing, shipped, delivered, cancelled
  paymentStatus String    @default("unpaid") // unpaid, partial, paid
  
  shippingAddress String?
  billingAddress String?
  notes         String?
  
  customer      Customer  @relation(fields: [customerId], references: [id])
  quotation     Quotation? @relation(fields: [quotationId], references: [id])
  items         SalesOrderItem[]
  invoices      Invoice[]
  shipments     Shipment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?

  @@index([orderNo])
  @@index([customerId])
  @@index([status])
}

model SalesOrderItem {
  id          String    @id @default(uuid())
  orderId     String
  productId   String
  
  description String?
  quantity    Decimal   @db.Decimal(15, 3)
  shippedQty  Decimal   @default(0) @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  discount    Decimal   @default(0) @db.Decimal(15, 2)
  tax         Decimal   @default(0) @db.Decimal(15, 2)
  subtotal    Decimal   @db.Decimal(15, 2)
  
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@index([orderId])
}

model Shipment {
  id            String    @id @default(uuid())
  shipmentNo    String    @unique
  salesOrderId  String
  warehouseId   String
  
  shipmentDate  DateTime  @default(now())
  carrier       String?
  trackingNo    String?
  
  status        String    @default("pending") // pending, shipped, in_transit, delivered
  deliveredAt   DateTime?
  
  notes         String?
  
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  items         ShipmentItem[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  shippedById   String?

  @@index([shipmentNo])
  @@index([salesOrderId])
  @@index([status])
}

model ShipmentItem {
  id          String   @id @default(uuid())
  shipmentId  String
  productId   String
  quantity    Decimal  @db.Decimal(15, 3)
  batchNumber String?
  
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([shipmentId])
}

// =====================================================
// FINANCE & ACCOUNTING MODULE
// =====================================================

model ChartOfAccount {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  type          String    // asset, liability, equity, revenue, expense
  category      String?
  parentId      String?
  description   String?
  isActive      Boolean   @default(true)
  isHeader      Boolean   @default(false)
  
  parent        ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      ChartOfAccount[] @relation("AccountHierarchy")
  
  journalEntryLines JournalEntryLine[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([type])
  @@index([isActive])
}

model FiscalYear {
  id          String    @id @default(uuid())
  name        String
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  status      String    @default("open") // open, closed
  
  periods     FiscalPeriod[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model FiscalPeriod {
  id          String     @id @default(uuid())
  yearId      String
  name        String
  periodNo    Int
  startDate   DateTime   @db.Date
  endDate     DateTime   @db.Date
  status      String     @default("open") // open, closed
  
  year        FiscalYear @relation(fields: [yearId], references: [id])
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([yearId, periodNo])
  @@index([status])
}

model JournalEntry {
  id            String    @id @default(uuid())
  entryNo       String    @unique
  entryDate     DateTime  @db.Date
  
  type          String    @default("general") // general, sales, purchase, payment, receipt, adjustment
  reference     String?
  referenceType String?
  referenceId   String?
  
  description   String?
  totalDebit    Decimal   @db.Decimal(15, 2)
  totalCredit   Decimal   @db.Decimal(15, 2)
  
  status        String    @default("draft") // draft, posted, voided
  postedAt      DateTime?
  
  lines         JournalEntryLine[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  postedById    String?

  @@index([entryNo])
  @@index([entryDate])
  @@index([status])
}

model JournalEntryLine {
  id          String    @id @default(uuid())
  entryId     String
  accountId   String
  
  description String?
  debit       Decimal   @default(0) @db.Decimal(15, 2)
  credit      Decimal   @default(0) @db.Decimal(15, 2)
  
  entry       JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@index([entryId])
  @@index([accountId])
}

model Invoice {
  id            String    @id @default(uuid())
  invoiceNo     String    @unique
  customerId    String
  salesOrderId  String?
  
  invoiceDate   DateTime  @default(now())
  dueDate       DateTime
  
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(15, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(15, 2)
  balanceDue    Decimal   @default(0) @db.Decimal(15, 2)
  
  status        String    @default("draft") // draft, sent, partial, paid, overdue, cancelled, void
  notes         String?
  terms         String?
  
  customer      Customer   @relation(fields: [customerId], references: [id])
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])
  items         InvoiceItem[]
  payments      PaymentAllocation[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([invoiceNo])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  
  description String
  quantity    Decimal   @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  discount    Decimal   @default(0) @db.Decimal(15, 2)
  tax         Decimal   @default(0) @db.Decimal(15, 2)
  subtotal    Decimal   @db.Decimal(15, 2)
  
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@index([invoiceId])
}

model Payment {
  id            String    @id @default(uuid())
  paymentNo     String    @unique
  customerId    String?
  supplierId    String?
  
  paymentDate   DateTime  @default(now())
  amount        Decimal   @db.Decimal(15, 2)
  
  type          String    // receipt, payment
  method        String    // cash, bank_transfer, credit_card, check
  reference     String?
  bankAccount   String?
  
  status        String    @default("pending") // pending, completed, cancelled
  notes         String?
  
  customer      Customer? @relation(fields: [customerId], references: [id])
  allocations   PaymentAllocation[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([paymentNo])
  @@index([customerId])
  @@index([status])
}

model PaymentAllocation {
  id          String    @id @default(uuid())
  paymentId   String
  invoiceId   String
  amount      Decimal   @db.Decimal(15, 2)
  
  payment     Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@unique([paymentId, invoiceId])
  @@index([paymentId])
  @@index([invoiceId])
}

model Expense {
  id            String    @id @default(uuid())
  expenseNo     String    @unique
  
  expenseDate   DateTime  @default(now())
  categoryId    String?
  
  description   String
  amount        Decimal   @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal   @db.Decimal(15, 2)
  
  paymentMethod String?
  reference     String?
  receipt       String?
  
  status        String    @default("pending") // pending, approved, rejected, paid
  approvedById  String?
  approvedAt    DateTime?
  
  notes         String?
  
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([expenseNo])
  @@index([status])
  @@index([expenseDate])
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  accountId   String?
  isActive    Boolean   @default(true)
  
  expenses    Expense[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TaxRate {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  rate        Decimal   @db.Decimal(5, 2)
  type        String    @default("percentage") // percentage, fixed
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BankAccount {
  id            String    @id @default(uuid())
  name          String
  accountNo     String    @unique
  bankName      String
  branch        String?
  currency      String    @default("IDR")
  balance       Decimal   @default(0) @db.Decimal(15, 2)
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  
  transactions  BankTransaction[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([accountNo])
  @@index([isActive])
}

model BankTransaction {
  id            String    @id @default(uuid())
  bankAccountId String
  
  transactionDate DateTime @default(now())
  type          String    // deposit, withdrawal, transfer
  amount        Decimal   @db.Decimal(15, 2)
  balance       Decimal   @db.Decimal(15, 2)
  
  reference     String?
  description   String?
  
  isReconciled  Boolean   @default(false)
  reconciledAt  DateTime?
  
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  
  createdAt     DateTime  @default(now())
  createdById   String?

  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
}

model Budget {
  id          String    @id @default(uuid())
  name        String
  fiscalYear  Int
  status      String    @default("draft") // draft, approved, active, closed
  
  items       BudgetItem[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  approvedById String?
  approvedAt  DateTime?

  @@unique([name, fiscalYear])
  @@index([fiscalYear])
  @@index([status])
}

model BudgetItem {
  id          String    @id @default(uuid())
  budgetId    String
  accountId   String?
  departmentId String?
  
  period      String
  amount      Decimal   @db.Decimal(15, 2)
  notes       String?
  
  budget      Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([budgetId])
}
